# ── Error tracking (Sentry) ──────────────────────────────────────────────────
# Sentry project DSN. Leave empty to disable error tracking (default for local dev).
# Get this from: https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# ── Usage analytics (Umami) ──────────────────────────────────────────────────
# Umami website ID. Leave empty to disable analytics (default for local dev).
# Get this from: https://umami.is or your self-hosted Umami instance → Website settings
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Umami script URL.
# Cloud:       https://cloud.umami.is/script.js
# Self-hosted: https://your-umami-instance.com/script.js
NEXT_PUBLIC_UMAMI_URL=

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
