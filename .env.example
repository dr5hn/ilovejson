# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ilovejson"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"   # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3002"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_ID=""
GITHUB_SECRET=""

# Email magic link (SMTP)
# For local dev, leave blank — the magic link will be logged to the server console instead.
EMAIL_SERVER=""   # e.g. smtp://user:pass@smtp.example.com:587
EMAIL_FROM=""     # e.g. "ilovejson <noreply@ilovejson.io>"
